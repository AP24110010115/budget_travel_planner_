#include <stdio.h>

#define MAX 100

struct City {
    int id;
    int cost;
    int enjoyment;
    float ratio;
};

void greedyPlan(struct City cities[], int n, int budget) {
    for (int i = 0; i < n; i++) {
        cities[i].ratio = (float)cities[i].enjoyment / cities[i].cost;
    }

    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (cities[i].ratio < cities[j].ratio) {
                struct City temp = cities[i];
                cities[i] = cities[j];
                cities[j] = temp;
            }
        }
    }

    int totalCost = 0, totalEnjoy = 0;

    printf("\n[Greedy Plan]\nCities selected: ");

    for (int i = 0; i < n; i++) {
        if (totalCost + cities[i].cost <= budget) {
            printf("%d ", cities[i].id);
            totalCost += cities[i].cost;
            totalEnjoy += cities[i].enjoyment;
        }
    }

    printf("\nTotal Cost: %d", totalCost);
    printf("\nTotal Enjoyment: %d\n", totalEnjoy);
}

void dpPlan(struct City cities[], int n, int budget) {
    int dp[MAX][MAX] = {0};

    for (int i = 1; i <= n; i++) {
        for (int w = 0; w <= budget; w++) {
            if (cities[i-1].cost <= w) {
                int include = cities[i-1].enjoyment + dp[i-1][w - cities[i-1].cost];
                int exclude = dp[i-1][w];
                dp[i][w] = (include > exclude) ? include : exclude;
            } else {
                dp[i][w] = dp[i-1][w];
            }
        }
    }

    printf("\n[DP Optimal Plan]\nMaximum Enjoyment: %d\n", dp[n][budget]);

    int w = budget;
    printf("Cities selected: ");
    for (int i = n; i > 0; i--) {
        if (dp[i][w] != dp[i-1][w]) {
            printf("%d ", cities[i-1].id);
            w -= cities[i-1].cost;
        }
    }
    printf("\n");
}

int main() {
    int n, budget;

    printf("Enter number of cities: ");
    scanf("%d", &n);

    struct City cities[MAX];

    printf("Enter cost and enjoyment for each city:\n");
    for (int i = 0; i < n; i++) {
        cities[i].id = i + 1;
        printf("City %d -> Cost Enjoyment: ", i + 1);
        scanf("%d %d", &cities[i].cost, &cities[i].enjoyment);
    }

    printf("Enter total budget: ");
    scanf("%d", &budget);

    struct City greedyCities[MAX];
    for (int i = 0; i < n; i++) {
        greedyCities[i] = cities[i];
    }

    greedyPlan(greedyCities, n, budget);
    dpPlan(cities, n, budget);

    return 0;
}
